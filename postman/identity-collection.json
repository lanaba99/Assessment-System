    {
      "name": "Invitation Flow",
      "description": "Closes the invite loop using the token captured by Users \u203a Invite User.",
      "item": [
        {
          "name": "Accept Invite",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{invited_user_email}}\",\n  \"token\": \"{{invite_token}}\",\n  \"password\": \"Welcome!Pass2025xyz\",\n  \"password_confirmation\": \"Welcome!Pass2025xyz\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{api_path}}/auth/accept-invite"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const tok = pm.environment.get('invite_token');",
                  "const email = pm.environment.get('invited_user_email');",
                  "if (!tok || !email) {",
                  "    console.log('Skipping Accept Invite \u2014 invite_token/invited_user_email not populated. Run Users \u203a Invite User first.');",
                  "    pm.execution.skipRequest();",
                  "}"
                ]
              }
            }
          ]
        }
      ]
