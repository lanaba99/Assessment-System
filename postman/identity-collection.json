          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Pick a session that isn't the one we are currently using so",
                  "// Revoke One Session in tear-down doesn't kill our auth mid-run.",
                  "try {",
                  "    const json = pm.response.json();",
                  "    const sessions = json && json.data ? json.data : [];",
                  "    const currentSid = pm.environment.get('session_id');",
                  "    const other = sessions.find(s => s.session_id !== currentSid);",
                  "    if (other) pm.environment.set('target_session_id', other.session_id);",
                  "} catch (e) { console.log('Sessions capture skipped:', e.message); }"
                ]
              }
            }
          ]
        }
