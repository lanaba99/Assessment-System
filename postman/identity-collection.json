            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Fallback target_user_id capture: prefer a user that isn't the",
                  "// logged-in admin (so we can deactivate/reset them later safely).",
                  "try {",
                  "    const json = pm.response.json();",
                  "    const rows = json && json.data ? json.data : [];",
                  "    const selfId = pm.environment.get('user_id');",
                  "    const other = rows.find(u => String(u.id || u.user_id) !== String(selfId));",
                  "    const pick = other || rows[0];",
                  "    if (pick) {",
                  "        const id = pick.id || pick.user_id;",
                  "        if (id) pm.environment.set('target_user_id', id);",
                  "    }",
                  "} catch (e) { console.log('List-users capture skipped:', e.message); }"
                ]
