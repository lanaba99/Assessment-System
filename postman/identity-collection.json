    {
      "name": "Tear-down (Destructive \u2014 runs LAST)",
      "description": "These endpoints invalidate auth state. They run AFTER every read/write test so they cannot kill the session mid-suite.\n\n- Refresh rotates the bearer (old token gone, new one captured into env).\n- Revoke One Session targets a non-current session (captured by My Sessions earlier).\n- Reset Forgotten Password is public; it skips unless reset_token is populated (paste from storage/logs/laravel.log to run it).\n- Revoke All Sessions destroys every bearer token for the user.\n- Logout runs LAST. By this point Revoke All has already cleared the token, so the test script for Revoke All clears the env token too \u2014 Logout is sent without auth and 204s gracefully.",
      "item": [
        {
          "name": "Refresh Session (Rotate Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"{{session_id}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{api_path}}/auth/refresh"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "    const json = pm.response.json();",
                  "    const data = json && json.data ? json.data : null;",
                  "    if (data && data.token) pm.environment.set('token', data.token);",
                  "} catch (e) { console.log('Refresh capture skipped:', e.message); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Revoke One Session",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}{{api_path}}/identity/sessions/{{target_session_id}}"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('target_session_id')) {",
                  "    console.log('Skipping Revoke One Session \u2014 only one active session exists (My Sessions captured nothing).');",
                  "    pm.execution.skipRequest();",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Reset Forgotten Password",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"token\": \"{{reset_token}}\",\n  \"password\": \"NewSecret!2025xyz\",\n  \"password_confirmation\": \"NewSecret!2025xyz\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{api_path}}/auth/password/reset"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const tok = pm.environment.get('reset_token');",
                  "if (!tok) {",
                  "    console.log('Skipping Reset Forgotten Password \u2014 reset_token not set. Populate it from storage/logs/laravel.log after running Forgot Password.');",
                  "    pm.execution.skipRequest();",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Revoke All Sessions",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}{{api_path}}/identity/sessions/all"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Revoke-all wiped every personal_access_token. Clear our cached",
                  "// token so the Logout request below is sent without an Authorization",
                  "// header (a stale token would render a 401 instead of 204).",
                  "if (pm.response.code === 204) {",
                  "    pm.environment.set('token', '');",
                  "    pm.environment.set('session_id', '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"00000000-0000-0000-0000-000000000000\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{api_path}}/auth/logout",
            "description": "Sent without auth because Revoke All Sessions already cleared every token. session_id is a placeholder \u2014 the endpoint requires the field for validation but the underlying session no longer exists."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// After Revoke All Sessions, there is no valid bearer token. The",
                  "// logout endpoint requires auth:sanctum, so without a token it",
                  "// will 401. Skip cleanly to keep the suite green \u2014 the equivalent",
                  "// state (session closed, token revoked) has already been reached.",
                  "if (!pm.environment.get('token')) {",
                  "    console.log('Skipping Logout \u2014 Revoke All Sessions already terminated this session.');",
                  "    pm.execution.skipRequest();",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}