            "url": "{{base_url}}{{api_path}}/system/status"
          }
        }
      ]
    },
    {
      "name": "Auth (Public)",
      "description": "No-bearer endpoints. Login seeds token/session_id/user_id/mfa_required for every authenticated request that follows.",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{api_path}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Capture everything Login emits, including whether the tenant",
                  "// requires MFA on this user (drives Verify MFA's skip logic).",
                  "try {",
                  "    const json = pm.response.json();",
                  "    const data = json && json.data ? json.data : null;",
                  "    if (data) {",
                  "        if (data.token)      pm.environment.set('token', data.token);",
                  "        if (data.session_id) pm.environment.set('session_id', data.session_id);",
                  "        if (data.user_id)    pm.environment.set('user_id', data.user_id);",
                  "        pm.environment.set('mfa_required', data.mfa_required ? 'true' : 'false');",
                  "        pm.environment.set('login_status', data.status || '');",
                  "    }",
                  "} catch (e) { console.log('Login capture skipped:', e.message); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify MFA",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"one_time_code\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{api_path}}/auth/mfa/verify"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Only meaningful when Login returned status=mfa_required. In a",
                  "// tenant where MFA is off, Login already returns an active token",
                  "// and this request would 401 \u2014 skip cleanly instead.",
                  "if (pm.environment.get('mfa_required') !== 'true') {",
                  "    console.log('Skipping Verify MFA \u2014 Login did not return an mfa_required session for this tenant.');",
                  "    pm.execution.skipRequest();",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "    const json = pm.response.json();",
                  "    const data = json && json.data ? json.data : null;",
                  "    if (data && data.token) pm.environment.set('token', data.token);",
                  "} catch (e) { console.log('MFA capture skipped:', e.message); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": {
