{
  "info": {
    "_postman_id": "de2e5520-7a93-4215-81e4-d0c416465510",
    "name": "EAE - Identity Module (Complete)",
    "description": "Complete Postman collection for the EAE Identity domain. Mirrors routes/tenant.php identity endpoints, FormRequest schemas, and Sanctum bearer-token auth.\n\nRun order suggestion:\n1. System Status\n2. Login → Verify MFA (if required)\n3. Protected endpoints\n\nCollection variables auto-populate sanctum_token, current_session_id, target_user_id, target_role_id, and invite_token from responses.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://alpha-engine.localhost/api/v1",
      "type": "string"
    },
    {
      "key": "tenant_id",
      "value": "",
      "type": "string",
      "description": "Tenant UUID. Set to your tenant key or rely on subdomain tenancy + X-Tenant-ID header."
    },
    {
      "key": "sanctum_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "current_session_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "current_user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "target_user_id",
      "value": "",
      "type": "string",
      "description": "UUID of a user for show/reset/deactivate/role assignment."
    },
    {
      "key": "target_role_id",
      "value": "",
      "type": "string",
      "description": "UUID of a role for update/delete/assignment."
    },
    {
      "key": "invite_token",
      "value": "",
      "type": "string",
      "description": "Invite token returned by POST /users/invite."
    },
    {
      "key": "password_reset_token",
      "value": "",
      "type": "string",
      "description": "Token from password reset email (manual)."
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const tenantId = pm.collectionVariables.get('tenant_id');",
          "if (tenantId) {",
          "    pm.request.headers.upsert({ key: 'X-Tenant-ID', value: tenantId });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01: Public & System",
      "description": "Unauthenticated endpoints. Tenancy resolved via subdomain or X-Tenant-ID header.",
      "item": [
        {
          "name": "System Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/system/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "system",
                "status"
              ]
            },
            "description": "GET /api/v1/system/status — Tenant-aware health check. Returns data.status, data.tenant_id, data.database, data.timestamp. No auth required."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Payload has data envelope', function () { pm.expect(json).to.have.property('data'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02: Authentication (Public)",
      "description": "Public auth endpoints. Login and MFA verify capture sanctum_token and current_session_id.",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "POST /api/v1/auth/login — Authenticate with email/password. Optional tenant_id in body when not using subdomain. Returns data.status, data.session_id, data.mfa_required, and data.token when fully authenticated.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tenant.admin@alpha-engine.example\",\n  \"password\": \"password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "    if (json.data.token) pm.collectionVariables.set('sanctum_token', json.data.token);",
                  "    if (json.data.session_id) pm.collectionVariables.set('current_session_id', json.data.session_id);",
                  "    if (json.data.user_id) pm.collectionVariables.set('current_user_id', json.data.user_id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify MFA",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/mfa/verify",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "mfa",
                "verify"
              ]
            },
            "description": "POST /api/v1/auth/mfa/verify — Complete MFA for pending session. Field is one_time_code (not code). Updates sanctum_token on success.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"{{current_session_id}}\",\n  \"one_time_code\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) pm.collectionVariables.set('sanctum_token', json.data.token);"
                ]
              }
            }
          ]
        },
